# API Keys
FINNHUB_API_KEY=your_finnhub_key_here
EULERPOOL_API_KEY=your_eulerpool_key_here
DATABENTO_API_KEY=your_databento_key_here_optional

# Database (Phase 1-2: local SQLite, Phase 3+: Supabase)
DB_PATH=data/swing_model.db
SUPABASE_URL=your_supabase_url_here
